pipeline {
    agent any

    tools {
        // Install the Maven version configured as "M3" and add it to the path.
        maven 'M3'
    }

    stages {
        stage('Build') {
            steps {
                echo 'Starting Maven phase'
                checkout scmGit(branches: [[name: '*/dev']], extensions: [], userRemoteConfigs: [[url: 'https://github.com/MraihiAmine/B2B_CRM']])
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Dockerization') {
            steps {
                script {
                    // Retrieve the MySQL_USER_PWD secret from Jenkins
                    def mySqlUserPwd = withCredentials([string(credentialsId: 'MySQL_user_pwd', variable: 'MySQL_USER_PWD')]) {
                        return env.MySQL_USER_PWD
                    }
                    // Build and start the Docker containers
                    sh "docker-compose build --build-arg MYSQL_USER_PWD='$mySqlUserPwd' --detach --verbose"
                    sh "docker-compose up -d"
                }
            }
        }
    }
}
